# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql+asyncpg://docint:docint@localhost:5432/docint

# Extraction model — claude-sonnet-4-6 is the best balance of speed and quality
EXTRACTION_MODEL=claude-sonnet-4-6

# Confidence threshold below which documents go to human review (0.0–1.0)
CONFIDENCE_THRESHOLD=0.75

# File storage — local path for uploaded documents
UPLOAD_DIR=./uploads
